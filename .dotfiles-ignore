#Ignore the bin.d local folder
/bin.d/local
#Ignore the bin.d overlay folder
/bin.d/overlay

# .bashrc.d
# Host machine-specific files are ignored by default to prevent accidental
# commits into the wrong repo
/.bashrc.d/host.*
# Ignore shell-script work-project aliases
/.bashrc.d/shell-scripts-aliases
# Ignore work Git details
/.bashrc.d/git-env-rpmpcg

# .m2
/.m2/repository/
/.m2/settings-security.xml
/.m2/settings.xml
/.m2/toolchains.xml
# Ignore host-specific files to avoid committing to the wrong repo
/.m2/settings@*.xml
/.m2/toolchains@*.xml

# .screenrc.d
# Ignore host-specific and overlay files to avoid committing to the wrong repo
/.screenrc.d/host.*
/.screenrc.d/overlay.*

# .ssh
/.ssh/*
!/.ssh/.gitignore
!/.ssh/config
!/.ssh/config.d
/.ssh/config.d/localhost
/.ssh/config.d/overlay.*

# .tmux.conf.d
# Ignore host-specific and overlay files to avoid committing to the wrong repo
/.tmux.conf.d/host.*
/.tmux.conf.d/overlay.*

